#!/usr/bin/env bash
# mise description: Download and extract shared test assets
# Usage: mise run download [--output-dir <dir>] <release-version> <project-name> <assets-version>
# Example: mise run download v2025.09 kiarina-python v1.0.0

set -e

REPO="kiarina/test-assets"
OUTPUT_DIR="tests/assets"

# Parse arguments
POSITIONAL_ARGS=()
while [[ "$#" -gt 0 ]]; do
    case $1 in
        --output-dir) OUTPUT_DIR="$2"; shift 2 ;;
        -*) echo "Unknown parameter: $1"; exit 1 ;;
        *) POSITIONAL_ARGS+=("$1"); shift ;;
    esac
done

set -- "${POSITIONAL_ARGS[@]}"

if [ "$#" -lt 3 ]; then
    echo "Usage: mise run download [--output-dir <dir>] <release-version> <project-name> <assets-version>"
    echo "Example: mise run download v2025.09 kiarina-python v1.0.0"
    exit 1
fi

RELEASE_VERSION=$1
PROJECT_NAME=$2
ASSETS_VERSION=$3

ASSET_FILENAME="${PROJECT_NAME}-assets-${ASSETS_VERSION}.tar.zst"
DOWNLOAD_URL="https://github.com/${REPO}/releases/download/${RELEASE_VERSION}/${ASSET_FILENAME}"

echo "======================================"
echo "Downloading Assets"
echo "Repository: $REPO"
echo "Release:    $RELEASE_VERSION"
echo "Asset:      $ASSET_FILENAME"
echo "Output Dir: $OUTPUT_DIR"
echo "======================================"

mkdir -p "$OUTPUT_DIR"

# Download
echo "Downloading from $DOWNLOAD_URL..."
if command -v curl &> /dev/null; then
    curl -L -f -o "$OUTPUT_DIR/$ASSET_FILENAME" "$DOWNLOAD_URL"
elif command -v wget &> /dev/null; then
    wget -qO "$OUTPUT_DIR/$ASSET_FILENAME" "$DOWNLOAD_URL"
else
    echo "Error: Neither curl nor wget is installed."
    exit 1
fi

# Extract
echo "Extracting archive..."
if ! command -v tar &> /dev/null; then
    echo "Error: tar is not installed."
    exit 1
fi

tar --use-compress-program=unzstd -xvf "$OUTPUT_DIR/$ASSET_FILENAME" -C "$OUTPUT_DIR"

# Cleanup
echo "Cleaning up..."
rm "$OUTPUT_DIR/$ASSET_FILENAME"

# Add to .gitignore if not present
GITIGNORE=".gitignore"
if [ ! -f "$GITIGNORE" ]; then
    touch "$GITIGNORE"
fi

# Clean output dir path for grep (remove trailing slash if any)
CLEAN_OUTPUT_DIR=${OUTPUT_DIR%/}
if ! grep -q "^${CLEAN_OUTPUT_DIR}/$" "$GITIGNORE" && ! grep -q "^${CLEAN_OUTPUT_DIR}$" "$GITIGNORE"; then
    echo "Adding $CLEAN_OUTPUT_DIR to $GITIGNORE..."
    echo "" >> "$GITIGNORE"
    echo "# Test assets downloaded via mise" >> "$GITIGNORE"
    echo "${CLEAN_OUTPUT_DIR}/" >> "$GITIGNORE"
fi

echo "======================================"
echo "Successfully downloaded and extracted assets to $OUTPUT_DIR/"
