#!/usr/bin/env bash
# mise description: Build release assets for a specific version

set -e

VERSION=$1

# Interactive prompt if version is not provided
if [ -z "$VERSION" ]; then
    if command -v fzf &> /dev/null; then
        echo "No version specified. Please select a version from src/:"
        VERSION=$(ls -1 src/ 2>/dev/null | sort -r | fzf --prompt="Select version: " || true)
        if [ -z "$VERSION" ]; then
            echo "Error: No version selected."
            exit 1
        fi
    else
        echo "No version specified. Please select a version from src/:"
        # Use array to safely handle paths (though they should be simple names like v2025.09)
        versions=($(ls -1 src/ 2>/dev/null | sort -r || true))
        
        if [ ${#versions[@]} -eq 0 ]; then
            echo "Error: No versions found in src/"
            exit 1
        fi
        
        select v in "${versions[@]}"; do
            if [ -n "$v" ]; then
                VERSION=$v
                break
            else
                echo "Invalid selection"
            fi
        done
    fi
fi

echo "======================================"
echo "Building release for version: $VERSION"
echo "======================================"

SRC_DIR="src/$VERSION"
RELEASE_DIR="release/$VERSION"

if [ ! -d "$SRC_DIR" ]; then
    echo "Error: Directory $SRC_DIR does not exist."
    exit 1
fi

# Ensure release directory exists and is clean
mkdir -p "$RELEASE_DIR"
rm -f "$RELEASE_DIR"/*.tar.zst "$RELEASE_DIR"/SHA256SUMS

# Package each asset directory inside the version directory
found_assets=false
for asset_dir in "$SRC_DIR"/*; do
    if [ -d "$asset_dir" ]; then
        found_assets=true
        asset_name=$(basename "$asset_dir")
        echo "Packaging $asset_name..."
        
        # Tar should be executed from within SRC_DIR so the paths in the tarball are relative
        (cd "$SRC_DIR" && tar --use-compress-program="zstd -T0 -10" -cvf "../../$RELEASE_DIR/$asset_name.tar.zst" "$asset_name")
    fi
done

if [ "$found_assets" = false ]; then
    echo "Warning: No asset directories found in $SRC_DIR."
fi

# Generate SHA256SUMS
if ls "$RELEASE_DIR"/*.tar.zst 1> /dev/null 2>&1; then
    echo "Generating SHA256SUMS..."
    (cd "$RELEASE_DIR" && sha256sum *.tar.zst > SHA256SUMS)
fi

# Update Uncompressed Size in src/MANIFEST.md dynamically
if [ -f "$SRC_DIR/MANIFEST.md" ]; then
    echo "Updating sizes in MANIFEST.md..."
    for asset_dir in "$SRC_DIR"/*; do
        if [ -d "$asset_dir" ]; then
            asset_name=$(basename "$asset_dir")
            size=$(du -sh "$asset_dir" | awk '{print $1}')
            
            # Use awk to find the specific asset section and update its size regardless of current value
            awk -v asset="## $asset_name.tar.zst" -v new_size="- **Uncompressed Size**: $size" '
            $0 == asset { in_asset=1; print; next }
            /^## / { in_asset=0 }
            in_asset && /^- \*\*Uncompressed Size\*\*:/ { print new_size; next }
            { print }
            ' "$SRC_DIR/MANIFEST.md" > "$SRC_DIR/MANIFEST.md.tmp"
            mv "$SRC_DIR/MANIFEST.md.tmp" "$SRC_DIR/MANIFEST.md"
        fi
    done
    
    cp "$SRC_DIR/MANIFEST.md" "$RELEASE_DIR/MANIFEST.md"
    echo "Copied MANIFEST.md"
else
    echo "# MANIFEST for $VERSION" > "$RELEASE_DIR/MANIFEST.md"
    echo "Auto-generated manifest. Please update with asset details." >> "$RELEASE_DIR/MANIFEST.md"
    echo "Created stub MANIFEST.md"
fi

echo "======================================"
echo "Build complete for $VERSION!"
echo "Assets generated in $RELEASE_DIR/"
